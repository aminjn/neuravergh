# --- Server ---
PORT=4000
NODE_ENV=production

# --- Database (PostgreSQL) ---
# یا DATABASE_URL کامل، یا فیلدهای جدا
DATABASE_URL=postgres://neura:neura@localhost:5432/neura
# PGHOST=localhost
# PGPORT=5432
# PGUSER=neura
# PGPASSWORD=neura
# PGDATABASE=neura

# --- Auth ---
# حتماً یک مقدار تصادفی و طولانی بگذار
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES=7d

# --- Seed: حساب اولیه سوپر‌ادمین ---
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=Admin@12345
SUPERADMIN_EMAIL=admin@neura.app
